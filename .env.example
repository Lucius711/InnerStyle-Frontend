# Origin of the InnerStyle backend API. Leave blank in dev to use the Vite proxy
# (which forwards /api -> http://localhost:2207). Set this for production builds.
VITE_API_BASE_URL=

# Optional: override the dev proxy target (defaults to http://localhost:2207)
VITE_API_PROXY_TARGET=http://localhost:2207

# Social login (public client IDs, embedded at build time). Leave blank to hide the buttons.
# Google: https://console.cloud.google.com → OAuth 2.0 Client ID (Web)
#   Add Authorized JavaScript origins: http://localhost:5173 and your prod domain.
VITE_GOOGLE_CLIENT_ID=
# Facebook: https://developers.facebook.com → App → Facebook Login → App ID
#   Add the same origins under Valid OAuth Redirect / App Domains.
VITE_FACEBOOK_APP_ID=
